<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup>
		<!-- Basic identity -->
		<AssemblyTitle>KC.Tik4Net</AssemblyTitle>
		<Product>KC.Tik4Net</Product>
		<Description>Async .NET 10+ client for MikroTik RouterOS, a modern successor to tik4net.</Description>
		<Company>KCtech</Company>
		<Authors>KC</Authors>

		<!-- Licensing and links -->
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
		<RepositoryUrl>https://github.com/KCTech-Lab/KC.Tik4Net</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://www.kctech.dk/aistudio/refactoring-tik4net</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>

		<!-- NuGet-facing metadata -->
		<PackageTags>mikrotik;routeros;networking;async;dotnet;kc.tik4net</PackageTags>

		<!-- Pre-1.0 semantic version -->
		<Version>0.9.0</Version>
	</PropertyGroup>


</Project>